rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function belongsToOrg(organizationId) {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.organizationId == organizationId;
    }

    function allowedImage() {
      return request.resource.contentType.matches('image/(png|jpeg|jpg|webp|svg\\+xml)');
    }

    function allowedPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    // organizations/{organizationId}/logos|receipts|signatures/**
    match /organizations/{organizationId}/{allPaths=**} {
      allow read: if belongsToOrg(organizationId);
      allow write: if belongsToOrg(organizationId)
        && request.resource.size <= 10 * 1024 * 1024
        && (allowedImage() || allowedPdf());
      allow delete: if belongsToOrg(organizationId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
