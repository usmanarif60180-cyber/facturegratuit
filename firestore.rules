rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validAccountDoc() {
      return request.resource.data.keys().hasOnly([
        'profile',
        'personal',
        'history',
        'projects',
        'clients',
        'products',
        'leads',
        'notifications',
        'storageUsedBytes',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow create, read, update, delete: if isOwner(userId) && validAccountDoc();

      match /{collectionName}/{docId} {
        allow read, create, update, delete: if isOwner(userId)
          && collectionName in ['history', 'projects', 'clients', 'products', 'feedback'];
      }
    }

    // ═══════════════════════════════════════════════
    // TEAM WORKSPACE — companies shared by multiple users.
    // Membership/role/invitation documents are written ONLY by Cloud
    // Functions (Admin SDK), which run the real permission checks — direct
    // client writes to those paths are denied here on purpose. Company-owned
    // business data (clients/projects/history/...) is read/write per the
    // caller's role within that company.
    // ═══════════════════════════════════════════════
    function roleWeight(role) {
      return role == 'owner' ? 5
        : role == 'admin' ? 4
        : role == 'manager' ? 3
        : role == 'accountant' ? 2
        : role == 'employee' ? 1
        : 0; // viewer
    }

    function membership(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data;
    }

    function isActiveMember(companyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid))
        && membership(companyId).status == 'active';
    }

    function hasMinRole(companyId, minRole) {
      return isActiveMember(companyId) && roleWeight(membership(companyId).role) >= roleWeight(minRole);
    }

    match /companies/{companyId} {
      allow read: if isActiveMember(companyId);
      allow create: if signedIn();
      allow update: if hasMinRole(companyId, 'admin');
      allow delete: if hasMinRole(companyId, 'owner');

      match /members/{memberUid} {
        allow read: if isActiveMember(companyId);
        allow write: if false; // Cloud Functions only
      }

      match /invitations/{inviteId} {
        allow read: if hasMinRole(companyId, 'admin');
        allow write: if false; // Cloud Functions only
      }

      match /clients/{clientId} {
        allow read: if isActiveMember(companyId);
        allow create, update: if hasMinRole(companyId, 'employee');
        allow delete: if hasMinRole(companyId, 'manager');
      }

      match /products/{productId} {
        allow read: if isActiveMember(companyId);
        allow create, update, delete: if hasMinRole(companyId, 'employee');
      }

      match /leads/{leadId} {
        allow read: if isActiveMember(companyId);
        allow create, update: if hasMinRole(companyId, 'employee');
        allow delete: if hasMinRole(companyId, 'manager');
      }

      match /history/{invoiceId} {
        allow read: if isActiveMember(companyId);
        allow create, update: if hasMinRole(companyId, 'accountant');
        allow delete: if hasMinRole(companyId, 'manager');
      }

      match /projects/{projectId} {
        allow read: if isActiveMember(companyId);
        allow create: if hasMinRole(companyId, 'manager');
        allow update: if hasMinRole(companyId, 'employee');
        allow delete: if hasMinRole(companyId, 'manager');

        match /tasks/{taskId} {
          allow read: if isActiveMember(companyId);
          allow create, update: if hasMinRole(companyId, 'employee');
          allow delete: if hasMinRole(companyId, 'manager');
        }

        match /comments/{commentId} {
          allow read: if isActiveMember(companyId);
          allow create: if isActiveMember(companyId) && request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if isActiveMember(companyId) && resource.data.authorUid == request.auth.uid;
        }

        match /activity/{activityId} {
          allow read: if isActiveMember(companyId);
          allow write: if false; // written by Cloud Functions / trusted client-side triggers only
        }

        match /documents/{docId} {
          allow read: if isActiveMember(companyId);
          allow create: if hasMinRole(companyId, 'employee');
          allow delete: if hasMinRole(companyId, 'manager');
        }
      }
    }

    // Lightweight per-user pointer so a client can list "which companies am I
    // in" without a collectionGroup query. Written only by Cloud Functions.
    match /userCompanyIndex/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /publicFeedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 3000;
      allow read, update, delete: if false;
    }

    match /publicConfig/{configId} {
      allow read: if configId in ['pricing'];
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
